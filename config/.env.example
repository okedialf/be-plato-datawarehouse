# =============================================================================
# EMIS Data Warehouse — Environment Configuration
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:   cp config/.env.example config/.env
#   2. Fill in values below for your environment
#   3. NEVER commit config/.env to git (it is in .gitignore)
#
# In production (GCP): set ENV=production and store secrets in
# GCP Secret Manager. The secret names match the variable names below
# in lowercase with underscores replaced by hyphens, e.g.:
#   DW_PASSWORD  →  secret name: dw-password
# =============================================================================

# ── Environment ────────────────────────────────────────────────────────────────
# Set to "production" on GCP to enable Secret Manager integration
ENV=local

# ── GCP Project ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# ── Data Warehouse (Cloud SQL PostgreSQL) ──────────────────────────────────────
# For local dev: use the Cloud SQL Auth Proxy (127.0.0.1:5432)
# For production: use the Cloud SQL private IP or Unix socket
DW_HOST=127.0.0.1
DW_PORT=5432
DW_NAME=emis_dw
DW_USER=etl_user
DW_PASSWORD=change_me
DW_SSLMODE=prefer

# ── OLTP Source Database ───────────────────────────────────────────────────────
# Use a READ-ONLY user on the OLTP database.
# Allow the DW host IP through the OLTP firewall on port 5432 only.
OLTP_HOST=your-oltp-host
OLTP_PORT=5432
OLTP_NAME=emis_oltp
OLTP_USER=etl_readonly
OLTP_PASSWORD=change_me
OLTP_SSLMODE=require

# ── Email Notifications ────────────────────────────────────────────────────────
# Leave NOTIFY_EMAIL blank to disable email alerts
NOTIFY_EMAIL=datawarehouse-team@example.com,another@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-sender@gmail.com
SMTP_PASSWORD=your-app-password
